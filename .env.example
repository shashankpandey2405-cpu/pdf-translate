# ============================================================
# PDFTrusted Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- Auth-only / payments paused (optional) ---
# When true, checkout CTAs hide until PayPal is configured and AUTH_ONLY_MODE=false.
VITE_AUTH_ONLY_MODE=
AUTH_ONLY_MODE=

# --- PayPal (sole payment provider) ---
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Webhook recommended for auto-fulfillment; checkout works with Client ID + Secret only
PAYPAL_WEBHOOK_ID=
# Billing plan IDs from PayPal Dashboard → Subscriptions
PAYPAL_PLAN_PREMIUM_MONTHLY=
PAYPAL_PLAN_PREMIUM_YEARLY=
# Webhook URL: https://your-domain/api/webhooks/paypal
# Return URL (automatic): https://your-domain/api/checkout/paypal/return
NEXT_PUBLIC_PAYMENTS_ENABLED=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
VITE_PAYMENTS_ENABLED=
VITE_PAYPAL_CLIENT_ID=
# Set AUTH_ONLY_MODE=false to enable checkout (see docs/FINAL_GO_LIVE.md)

# --- Google AdSense (optional; display slots off in code by default) ---
# Display slots stay off in code until you enable AdSlot; keep client ID for verification only.
# VITE_ADSENSE_CLIENT_ID=
# VITE_ADSENSE_SLOT_TOP=
# VITE_ADSENSE_SLOT_SIDEBAR=
# VITE_ADSENSE_SLOT_BOTTOM=
# VITE_ADSENSE_SLOT_IN_ARTICLE=

# --- Local dev (Vite + Wrangler) ---
# Vite defaults to proxying /api → http://127.0.0.1:3001 in development. Run both:
#   npm run dev:full
# Or point only the SPA at a deployed Worker:
#   VITE_API_PROXY_TARGET=https://www.pdftrusted.com
# To disable the default :3001 proxy (no /api in dev):
#   VITE_API_PROXY_TARGET=-
VITE_API_PROXY_TARGET=
# Simulate premium tier in dev when set to true
VITE_MOCK_PREMIUM=

# --- Stripe (for Premium subscriptions) ---
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PREMIUM_PRICE_ID=your_stripe_price_id

# --- OpenAI (for future AI PDF chat feature) ---
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# --- Cloudflare Workers AI (for AI PDF Translator) ---
# Get from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
# Optional model override for Magic Eraser image inpainting/object removal
CLOUDFLARE_AI_IMAGE_MODEL=@cf/runwayml/stable-diffusion-v1-5-inpainting
# --- OpenRouter (sole AI provider — translate + summarize on Vercel/Railway) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Primary paid models (cheap + reliable on OpenRouter)
OPENROUTER_MODEL_TRANSLATE=deepseek/deepseek-chat
OPENROUTER_MODEL_SUMMARIZE=deepseek/deepseek-chat
# 1 = paid models first (default). 0 = free-first for small jobs only.
AI_PREFER_PAID_FIRST=1
OPENROUTER_MODEL_FREE=openai/gpt-oss-20b:free
OPENROUTER_MODEL_FREE_FALLBACKS=nvidia/nemotron-3-nano-30b-a3b:free,meta-llama/llama-3.2-3b-instruct:free,nvidia/nemotron-nano-9b-v2:free,google/gemma-4-26b-a4b-it:free
# Paid fallbacks after primary (comma-separated, low-cost order)
OPENROUTER_FALLBACK_MODELS=google/gemini-2.5-flash,openai/gpt-4o-mini
OPENROUTER_APP_URL=https://www.pdftrusted.com
OPENROUTER_APP_NAME=PdfTrusted
AI_PLUS_MAX_FILE_MB=5
AI_PLUS_MAX_PAGES=2
AI_LIFETIME_TRIAL_LIMIT=0
# Legacy (unused)
AI_DAILY_TRIAL_LIMIT=20

# --- Classic Translate PDF (self-hosted open-source MT, no OpenRouter) ---
# Deploy docker/translate-mt (see docs/TRANSLATE_CLASSIC_DEPLOY.md)
TRANSLATE_MT_URL=http://localhost:5000
TRANSLATE_MT_TIMEOUT_MS=120000
CLASSIC_MT_BASE_CREDITS=2
CLASSIC_MT_BATCH_SIZE=80

# --- Phase 3: Railway AI worker (queue drain off Vercel by default) ---
# railway = Redis queue consumed by `npm run worker:ai` on Railway
AI_WORKER_RUNTIME=railway
# Set true only for local dev / emergency Vercel drain
AI_QUEUE_DRAIN_ON_VERCEL=
# Force Vercel to drain even when runtime=railway
DISABLE_RAILWAY_AI_WORKER=
# Required on Vercel to wake /api/internal/ai-process after enqueue (same value as cron auth)
CRON_SECRET=
# Optional HTTP wake after enqueue (Railway service URL, not the public Vercel URL)
RAILWAY_AI_WORKER_PING_URL=
RAILWAY_AI_WORKER_SECRET=
AI_WORKER_POLL_MS=2500
AI_WORKER_BATCH_SIZE=1
# Optional: durable rate limits if you add KV later (not required for core PDFTrusted).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- App Configuration ---
VITE_APP_NAME=PDFTrusted
VITE_APP_URL=https://www.pdftrusted.com

# --- Monitoring (Sentry + GA4 + Search Console) ---
VITE_SENTRY_DSN=
VITE_SENTRY_TUNNEL=/api/sentry-tunnel
VITE_GA_MEASUREMENT_ID=
VITE_APP_RELEASE=
VITE_GOOGLE_SITE_VERIFICATION=

# --- Trusted Cloud (Redis queue + Railway workers) ---
# REDIS_URL=redis://...  (Railway Redis PUBLIC TCP URL on Vercel + every worker service)
# RENDER_WORKER_SECRET=  (same on Vercel + backend-service workers)
# ENHANCED_CALLBACK_URL=https://www.pdftrusted.com
# NEXT_PUBLIC_ENHANCED_ENABLED=true
# Set true only after Railway workers pop priority queues (premium → default → free):
WORKERS_PRIORITY_QUEUES=false

# --- Trusted Cloud limits (Vercel Production) ---
# Legacy daily cloud cap (unused for free tier — quota is monthly credits in app code)
ENHANCED_DAILY_LIMIT=2
ENHANCED_TRIAL_MAX_FILE_MB=15
ENHANCED_TRIAL_MAX_PAGES=10
ENHANCED_MAX_FILE_MB=60
ENHANCED_PREMIUM_MAX_FILE_MB=500
ENHANCED_STANDARD_MAX_PAGES=50
ENHANCED_PREMIUM_MAX_PAGES=100
ENHANCED_OCR_MAX_PAGES=20
ENHANCED_IP_DAILY_LIMIT=30
ENHANCED_PRESIGN_HOURLY_LIMIT=8
ENHANCED_PRESIGN_DAILY_LIMIT=25
# NEVER on production: PDFTRUSTED_QA_MODE, NEXT_PUBLIC_PDFTRUSTED_QA_MODE
# Optional owner bypass (comma UUIDs): ENHANCED_UNLIMITED_USER_IDS=

# --- S3 / R2 Multipart Upload ---
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Auth.js (Google OAuth + email/password) ---
# AUTH_SECRET (or NEXTAUTH_SECRET): random string, e.g. openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
# Leave AUTH_TRUST_HOST=true so Auth.js trusts Cloudflare edge forwarded Host / proto headers
# and builds redirect URLs from the actual request origin (https://www.pdftrusted.com in prod,
# localhost:3000 in dev). Required for the multi-origin redirect URI setup below.
AUTH_TRUST_HOST=true
# Google: use either pair (AUTH_* is preferred in this repo)
# Authorized JavaScript origins in Google Cloud Console:
#   https://www.pdftrusted.com
#   http://localhost:3000
#   http://localhost:3001   (wrangler dev; only if you load the SPA from the Worker origin)
# Authorized redirect URIs:
#   https://www.pdftrusted.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3001/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of your app. Used in password-reset emails AND as the canonical origin when
# the request lacks a forwarded-host header. In production set to https://www.pdftrusted.com.
AUTH_URL=
# Same as NextAuth / Google OAuth console: canonical site URL (e.g. http://localhost:3000 for local)
NEXTAUTH_URL=
# Where Auth.js sends users on error; should match your i18n prefix (e.g. /en/login)
AUTH_SIGNIN_PATH=/en/login
# Resend (https://resend.com) for password-reset emails. Without these, reset links are only logged in dev.
RESEND_API_KEY=
AUTH_EMAIL_FROM=
