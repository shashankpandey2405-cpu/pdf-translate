{
  "name": "pdftrusted",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "browserslist": [
    "chrome >= 87",
    "edge >= 88",
    "firefox >= 78",
    "safari >= 14"
  ],
  "scripts": {
    "dev": "node scripts/dev-next.mjs",
    "dev:clean": "node scripts/dev-next.mjs --clean",
    "build": "node scripts/make-icons.mjs && node scripts/copy-pdf-worker.mjs && node scripts/verify-pdfjs-worker-version.mjs && node scripts/generate-sitemap.mjs && next build && node scripts/bundle-size-report.mjs && node scripts/verify-opencv-chunk.mjs && node scripts/bundle-baseline.mjs --phase=post-build",
    "brand:ingest": "node scripts/ingest-brand-sources.mjs",
    "brand:icons": "node scripts/make-icons.mjs",
    "build:gate": "npm run build && node scripts/bundle-size-report.mjs --gate",
    "start": "next start",
    "dev:vite": "vite",
    "bundle:report": "node scripts/bundle-size-report.mjs",
    "bundle:gate": "node scripts/bundle-size-report.mjs --gate",
    "verify:opencv-chunk": "node scripts/verify-opencv-chunk.mjs",
    "bundle:baseline": "node scripts/bundle-baseline.mjs --init",
    "analyze": "node scripts/analyze-bundle.mjs",
    "typecheck": "tsc --noEmit",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "audit:predeploy": "node scripts/validate-vercel-cron.mjs && node scripts/validate-production-env.mjs && node scripts/audit-routes.mjs && npm run typecheck && node scripts/verify-pdfjs-worker-version.mjs --strict && npm run qa:unit && npm run qa:assert-prod",
    "audit:tool-ux": "node scripts/audit-tool-ux.mjs",
    "audit:platform-mobile": "node scripts/audit-platform-mobile.mjs",
    "audit:onboarding": "node scripts/audit-routes-onboarding.mjs",
    "audit:seo-platform": "node scripts/audit-seo-platform.mjs",
    "audit:lighthouse": "node scripts/audit-lighthouse.mjs",
    "audit:lighthouse:desktop": "node scripts/audit-lighthouse-desktop.mjs",
    "qa:infra-report": "node scripts/generate-production-infra-report.mjs",
    "worker:health": "node backend-service/scripts/worker-healthcheck.mjs",
    "worker:ai": "tsx --tsconfig tsconfig.worker.json server/workers/runAiWorker.ts",
    "worker:translate": "tsx --tsconfig tsconfig.worker.json server/workers/runTranslateWorker.ts",
    "tool-smoke": "node scripts/tool-smoke.mjs",
    "diagnostics:enhanced": "node scripts/diagnostics-enhanced.mjs",
    "env:wizard": "node scripts/env-wizard.mjs",
    "qa:diagnostics": "node scripts/diagnostics-enhanced.mjs",
    "qa:fixtures": "node scripts/qa-generate-fixtures.mjs",
    "qa:unit": "vitest run",
    "qa:api": "node tests/api/run.mjs",
    "qa:e2e": "playwright test",
    "qa:matrix": "node scripts/qa-tool-matrix.mjs",
    "qa:queue": "node scripts/qa-queue-audit.mjs",
    "qa:infra": "node scripts/infra-audit.mjs",
    "qa:trust-copy": "node scripts/audit-trust-copy.mjs",
    "qa:stress": "node scripts/qa-stress-health.mjs",
    "qa:jobs-pools": "node scripts/qa-jobs-all-pools.mjs",
    "qa:cloud-e2e": "node scripts/qa-cloud-e2e.mjs",
    "reports:launch": "node scripts/generate-launch-reports.mjs",
    "qa:report": "node scripts/qa-report.mjs",
    "qa:assert-prod": "node scripts/qa-assert-no-prod-qa.mjs",
    "qa": "node scripts/qa-run.mjs",
    "audit:360-pdf": "node scripts/audit-report-to-pdf.mjs",
    "deploy:vercel:prod": "vercel deploy --prod --yes --scope armanpanday12-lgtms-projects"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@napi-rs/canvas": "^0.1.100",
    "@pdf-lib/fontkit": "^1.1.1",
    "@sentry/nextjs": "^9.47.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "comlink": "^4.4.2",
    "dompurify": "^3.4.7",
    "eslint-config-next": "15.5.18",
    "fabric": "^7.3.1",
    "fflate": "^0.8.2",
    "heic2any": "^0.0.4",
    "html2canvas": "^1.4.1",
    "i18next": "^26.1.0",
    "idb-keyval": "^6.2.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "mupdf": "^1.27.0",
    "next": "15.5.18",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^5.5.7",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.7",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "regenerator-runtime": "^0.14.1",
    "resend": "^6.12.3",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.19.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.100.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "critters": "^0.0.23",
    "esbuild": "^0.28.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "pngjs": "^7.0.0",
    "react-hook-form": "^7.55.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "wouter": "^3.3.5",
    "zod": "^3.23.8"
  }
}
